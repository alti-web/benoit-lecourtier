---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pathname = Astro.url.pathname;
const navLinks = [
  { href: `${base}/`, label: 'Accueil' },
  { href: `${base}/projets`, label: 'Projets' },
  { href: `${base}/tih-rse-agefiph-toulon`, label: 'TIH / RSE' },
  { href: `${base}/a-propos`, label: 'À propos' },
  { href: `${base}/contact`, label: 'Contact' },
];
const technoLinks = [
  { href: `${base}/developpeur-react-toulon`, label: 'React.js', color: 'text-cyan-400' },
  { href: `${base}/developpeur-nextjs-toulon`, label: 'Next.js', color: 'text-white' },
  { href: `${base}/developpeur-astro-toulon`, label: 'Astro JS', color: 'text-orange-400' },
];
const isTechnoActive = technoLinks.some(l => pathname === l.href);
---

<header class="fixed top-0 w-full z-50 bg-surface/80 dark:bg-surface-dark/80 backdrop-blur-md border-b border-gray-200/50 dark:border-gray-700/50 transition-colors duration-300">
  <nav class="container-narrow mx-auto flex items-center justify-between h-16 px-6">
    <a href="/" class="flex flex-col leading-tight">
      <span class="text-xl font-bold text-accent dark:text-blue-400 tracking-tight">Benoit Lecourtier</span>
      <span class="text-[10px] font-medium text-text-muted dark:text-text-dark-muted tracking-wide">AstroJS / React.js / Next.js — à Toulon</span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-6">
      {navLinks.slice(0, 2).map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'text-sm font-medium transition-colors duration-200 hover:text-accent dark:hover:text-blue-400',
            pathname === href
              ? 'text-accent dark:text-blue-400'
              : 'text-text-muted dark:text-text-dark-muted',
          ]}
        >
          {label}
        </a>
      ))}

      <!-- Techno dropdown -->
      <div class="relative group">
        <button
          class:list={[
            'text-sm font-medium transition-colors duration-200 hover:text-accent dark:hover:text-blue-400 flex items-center gap-1',
            isTechnoActive
              ? 'text-accent dark:text-blue-400'
              : 'text-text-muted dark:text-text-dark-muted',
          ]}
        >
          Techno
          <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
          <div class="bg-gray-800 border border-gray-700 rounded-xl p-2 shadow-2xl min-w-[200px]">
            {technoLinks.map(({ href, label, color }) => (
              <a
                href={href}
                class:list={[
                  'block px-4 py-2.5 rounded-lg text-sm font-medium transition-colors hover:bg-gray-700/50',
                  pathname === href ? color : 'text-text-dark-muted hover:text-text-dark',
                ]}
              >
                {label}
              </a>
            ))}
          </div>
        </div>
      </div>

      {navLinks.slice(2).map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'text-sm font-medium transition-colors duration-200 hover:text-accent dark:hover:text-blue-400',
            pathname === href
              ? 'text-accent dark:text-blue-400'
              : 'text-text-muted dark:text-text-dark-muted',
          ]}
        >
          {label}
        </a>
      ))}
      <a href={`${base}/contact`} class="text-sm font-bold px-4 py-2 bg-emerald-500 text-white rounded-full hover:bg-emerald-400 transition-all duration-200 shadow-md shadow-emerald-500/20 flex items-center gap-1.5">
        <span class="w-2 h-2 rounded-full bg-white animate-pulse"></span>
        Disponible immédiatement
      </a>
    </div>

    <!-- Mobile menu button -->
    <div class="flex items-center gap-2 md:hidden">
      <button
        id="mobile-menu-btn"
        class="p-2 rounded-lg text-text-muted dark:text-text-dark-muted hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
        aria-label="Menu"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path id="menu-icon" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-surface dark:bg-surface-dark border-b border-gray-200 dark:border-gray-700 transition-colors">
    <div class="px-6 py-4 space-y-3">
      {navLinks.slice(0, 2).map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'block text-sm font-medium py-2 transition-colors',
            pathname === href
              ? 'text-accent dark:text-blue-400'
              : 'text-text-muted dark:text-text-dark-muted hover:text-accent dark:hover:text-blue-400',
          ]}
        >
          {label}
        </a>
      ))}

      <!-- Techno submenu mobile -->
      <div class="py-2">
        <p class="text-xs font-semibold uppercase tracking-wider text-text-dark-muted mb-2">Techno</p>
        <div class="pl-3 space-y-1 border-l-2 border-gray-700">
          {technoLinks.map(({ href, label, color }) => (
            <a
              href={href}
              class:list={[
                'block text-sm font-medium py-1.5 transition-colors',
                pathname === href ? color : 'text-text-dark-muted hover:text-text-dark',
              ]}
            >
              {label}
            </a>
          ))}
        </div>
      </div>

      {navLinks.slice(2).map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'block text-sm font-medium py-2 transition-colors',
            pathname === href
              ? 'text-accent dark:text-blue-400'
              : 'text-text-muted dark:text-text-dark-muted hover:text-accent dark:hover:text-blue-400',
          ]}
        >
          {label}
        </a>
      ))}
      <a href={`${base}/contact`} class="inline-flex items-center gap-1.5 text-sm font-bold px-4 py-2 mt-2 bg-emerald-500 text-white rounded-full hover:bg-emerald-400 transition-all duration-200">
        <span class="w-2 h-2 rounded-full bg-white animate-pulse"></span>
        Disponible immédiatement
      </a>
    </div>
  </div>
</header>

<script>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
