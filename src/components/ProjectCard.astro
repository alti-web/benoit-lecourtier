---
interface Props {
  title: string;
  description: string;
  image: string;
  techs: string[];
  metric?: string;
  url?: string;
  sourceUrl?: string;
  delay?: number;
}

const { title, description, image, techs, metric, url, sourceUrl, delay = 0 } = Astro.props;
---

<div class="fade-in group bg-white dark:bg-gray-800/50 rounded-xl border border-gray-100 dark:border-gray-700/50 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300" style={`transition-delay: ${delay}ms`}>
  <!-- Project image -->
  <div class="aspect-video bg-gray-100 dark:bg-gray-700 overflow-hidden">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
  </div>

  <div class="p-6">
    <div class="flex items-start justify-between mb-2">
      <h3 class="text-lg font-semibold">{title}</h3>
      {metric && (
        <span class="text-xs font-mono bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 px-2 py-1 rounded-full whitespace-nowrap ml-2">
          {metric}
        </span>
      )}
    </div>

    <p class="text-sm text-text-muted dark:text-text-dark-muted leading-relaxed mb-4">{description}</p>

    <div class="flex flex-wrap gap-2 mb-4">
      {techs.map((tech) => (
        <span class="text-xs font-medium bg-gray-100 dark:bg-gray-700 text-text-muted dark:text-text-dark-muted px-2.5 py-1 rounded-md">
          {tech}
        </span>
      ))}
    </div>

    <div class="flex items-center gap-4 text-sm">
      {url && url !== '#' && (
        <a href={url} target="_blank" rel="noopener" class="text-accent dark:text-blue-400 font-medium hover:underline">
          Voir le site &rarr;
        </a>
      )}
      {sourceUrl && (
        <a href={sourceUrl} target="_blank" rel="noopener" class="text-text-muted dark:text-text-dark-muted hover:text-accent dark:hover:text-blue-400">
          Code source
        </a>
      )}
    </div>
  </div>
</div>
