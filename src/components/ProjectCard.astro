---
interface Props {
  title: string;
  description: string;
  image: string;
  techs: string[];
  metric?: string;
  context?: string;
  duration?: string;
  team?: string;
  url?: string;
  sourceUrl?: string;
  delay?: number;
}

const { title, description, image, techs, metric, context, duration, team, url, sourceUrl, delay = 0 } = Astro.props;
---

<div class="fade-in group bg-white dark:bg-gray-800/50 rounded-xl border border-gray-100 dark:border-gray-700/50 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300" style={`transition-delay: ${delay}ms`}>
  <!-- Project image -->
  <div class="aspect-video bg-gray-100 dark:bg-gray-700 overflow-hidden">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
  </div>

  <div class="p-6">
    <div class="flex items-start justify-between mb-1">
      <h3 class="text-lg font-semibold">{title}</h3>
      {metric && (
        <span class="text-xs font-mono bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 px-2 py-1 rounded-full whitespace-nowrap ml-2">
          {metric}
        </span>
      )}
    </div>

    {context && (
      <span class="inline-block text-xs font-medium text-blue-600 dark:text-blue-400 mb-2">{context}</span>
    )}

    <p class="text-sm text-text-muted dark:text-text-dark-muted leading-relaxed mb-3">{description}</p>

    {(duration || team) && (
      <div class="flex flex-wrap gap-3 mb-3 text-xs text-text-muted dark:text-text-dark-muted">
        {duration && (
          <span class="flex items-center gap-1">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            {duration}
          </span>
        )}
        {team && (
          <span class="flex items-center gap-1">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            {team}
          </span>
        )}
      </div>
    )}

    <div class="flex flex-wrap gap-1.5 mb-4">
      {techs.map((tech) => (
        <span class="text-xs font-medium bg-gray-100 dark:bg-gray-700 text-text-muted dark:text-text-dark-muted px-2 py-0.5 rounded-md">
          {tech}
        </span>
      ))}
    </div>

    <div class="flex items-center gap-4 text-sm">
      {url && url !== '#' && (
        <a href={url} target="_blank" rel="noopener" class="text-accent dark:text-blue-400 font-medium hover:underline">
          Voir le site &rarr;
        </a>
      )}
      {sourceUrl && (
        <a href={sourceUrl} target="_blank" rel="noopener" class="text-text-muted dark:text-text-dark-muted hover:text-accent dark:hover:text-blue-400 flex items-center gap-1">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          GitHub
        </a>
      )}
    </div>
  </div>
</div>
