---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Développeur web freelance à Toulon — React, Next.js, Astro. Applications web modernes, rapides et sur mesure.' } = Astro.props;
---

<!doctype html>
<html lang="fr" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="développeur toulon, freelance toulon, astrojs toulon, reactjs toulon, next.js toulon, développeur web freelance var" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
    <meta name="google-site-verification" content="cTPc02yWAU3w1yvyhKx7pT8m6ULNnAfWRzE6e-7Rhug" />
    <title>{title}</title>

    <!-- Google Ads (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-864211062" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'AW-864211062');
    </script>
    <!-- Google Ads event - delayed navigation helper -->
    <script is:inline>
      function gtagSendEvent(url) {
        var callback = function () {
          if (typeof url === 'string') {
            window.location = url;
          }
        };
        gtag('event', 'nous_contacter', {
          'event_callback': callback,
          'event_timeout': 2000,
        });
        return false;
      }
    </script>

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "https://benoit-lecourtier.vercel.app/#website",
          "url": "https://benoit-lecourtier.vercel.app",
          "name": "Benoit Lecourtier — Développeur Web Freelance",
          "description": "Développeur web freelance à Toulon spécialisé React.js, Next.js et Astro JS.",
          "inLanguage": "fr-FR"
        },
        {
          "@type": "Person",
          "@id": "https://benoit-lecourtier.vercel.app/#person",
          "name": "Benoit Lecourtier",
          "url": "https://benoit-lecourtier.vercel.app",
          "image": "https://benoit-lecourtier.vercel.app/652295112_26561412926797987_2650508981147995043_n.jpg",
          "jobTitle": "Développeur Web Frontend Freelance",
          "description": "Développeur web freelance spécialisé React.js, Next.js et Astro JS, basé à Toulon.",
          "knowsAbout": ["React.js", "Next.js", "Astro JS", "TypeScript", "Tailwind CSS", "JavaScript", "HTML", "CSS"],
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Toulon",
            "addressRegion": "Var",
            "postalCode": "83000",
            "addressCountry": "FR"
          }
        },
        {
          "@type": "ProfessionalService",
          "@id": "https://benoit-lecourtier.vercel.app/#business",
          "name": "Benoit Lecourtier — Développeur Web Freelance",
          "url": "https://benoit-lecourtier.vercel.app",
          "image": "https://benoit-lecourtier.vercel.app/652295112_26561412926797987_2650508981147995043_n.jpg",
          "description": "Développeur web freelance à Toulon. Création de sites et applications web avec React.js, Next.js et Astro JS.",
          "priceRange": "€€",
          "areaServed": {
            "@type": "GeoCircle",
            "geoMidpoint": {
              "@type": "GeoCoordinates",
              "latitude": 43.1242,
              "longitude": 5.928
            },
            "geoRadius": "50000"
          },
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Toulon",
            "addressRegion": "Var",
            "postalCode": "83000",
            "addressCountry": "FR"
          },
          "founder": { "@id": "https://benoit-lecourtier.vercel.app/#person" },
          "knowsAbout": ["Développement web", "React.js", "Next.js", "Astro JS", "TypeScript", "Applications web", "Sites vitrines"],
          "hasOfferCatalog": {
            "@type": "OfferCatalog",
            "name": "Services de développement web",
            "itemListElement": [
              {
                "@type": "Offer",
                "itemOffered": {
                  "@type": "Service",
                  "name": "Développement d'applications web React.js",
                  "description": "SPAs, dashboards, apps métier avec React.js et TypeScript"
                }
              },
              {
                "@type": "Offer",
                "itemOffered": {
                  "@type": "Service",
                  "name": "Développement Next.js full-stack",
                  "description": "Sites et applications avec SSR, SSG, API Routes et App Router"
                }
              },
              {
                "@type": "Offer",
                "itemOffered": {
                  "@type": "Service",
                  "name": "Création de sites Astro JS",
                  "description": "Sites vitrines ultra-rapides, blogs et landing pages avec Astro"
                }
              }
            ]
          }
        },
        {
          "@type": "WebPage",
          "url": new URL(Astro.url.pathname, Astro.site).href,
          "name": title,
          "description": description,
          "isPartOf": { "@id": "https://benoit-lecourtier.vercel.app/#website" },
          "about": { "@id": "https://benoit-lecourtier.vercel.app/#person" },
          "inLanguage": "fr-FR"
        }
      ]
    })} />
  </head>
  <body>
    <!-- Overlay fermeture (visible uniquement pour les humains, masqué pour les bots) -->
    <div id="closure-overlay" class="fixed inset-0 z-[9999] bg-gray-950 flex items-center justify-center p-6" style="display:none;">
      <div class="max-w-lg w-full text-center">
        <div class="mb-8">
          <svg class="w-16 h-16 mx-auto text-orange-500 mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
          </svg>
          <h1 class="text-2xl md:text-3xl font-bold text-white mb-4">Activit&eacute; ferm&eacute;e depuis 2024</h1>
          <p class="text-gray-400 text-lg">Suite &agrave; un accident de vie.</p>
        </div>
        <button id="closure-show-docs" class="inline-flex items-center gap-2 px-6 py-3 bg-orange-500 text-white font-semibold rounded-xl hover:bg-orange-400 transition-colors shadow-lg shadow-orange-500/20">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
          Justificatif administratif et juridique de la fermeture
        </button>
        <div id="closure-docs" class="hidden mt-8 space-y-3 text-left">
          <a href="/docs/aah-permanent.pdf" target="_blank" class="flex items-center gap-3 p-4 bg-gray-900 border border-gray-800 rounded-xl hover:border-orange-500/50 transition-colors group">
            <svg class="w-8 h-8 text-red-500 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 2l5 5h-5V4zM6 20V4h5v7h7v9H6z"/></svg>
            <div>
              <p class="text-white font-medium group-hover:text-orange-400 transition-colors">AAH sans date de fin (permanent)</p>
              <p class="text-gray-500 text-sm">Allocation Adulte Handicap&eacute;</p>
            </div>
          </a>
          <a href="/docs/cloture-etablissement.pdf" target="_blank" class="flex items-center gap-3 p-4 bg-gray-900 border border-gray-800 rounded-xl hover:border-orange-500/50 transition-colors group">
            <svg class="w-8 h-8 text-red-500 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 2l5 5h-5V4zM6 20V4h5v7h7v9H6z"/></svg>
            <div>
              <p class="text-white font-medium group-hover:text-orange-400 transition-colors">Cl&ocirc;ture de l'&eacute;tablissement</p>
              <p class="text-gray-500 text-sm">Radiation de l'activit&eacute;</p>
            </div>
          </a>
          <a href="/docs/mise-sous-curatelle.pdf" target="_blank" class="flex items-center gap-3 p-4 bg-gray-900 border border-gray-800 rounded-xl hover:border-orange-500/50 transition-colors group">
            <svg class="w-8 h-8 text-red-500 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 2l5 5h-5V4zM6 20V4h5v7h7v9H6z"/></svg>
            <div>
              <p class="text-white font-medium group-hover:text-orange-400 transition-colors">Mise sous curatelle renforc&eacute;e</p>
              <p class="text-gray-500 text-sm">D&eacute;cision du tribunal</p>
            </div>
          </a>
        </div>
      </div>
    </div>

    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Sticker "Rappel immédiat" -->
    <div id="callback-sticker" class="hidden md:block fixed left-0 top-1/2 -translate-y-1/2 z-40">
      <button id="callback-toggle" class="flex items-center gap-2 px-4 py-3 bg-orange-500 text-white text-sm font-bold rounded-r-full shadow-lg shadow-orange-500/30 hover:bg-orange-400 hover:shadow-xl transition-all duration-200">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        Rappel immédiat
      </button>
      <div id="callback-form" class="hidden absolute left-0 top-full mt-2 bg-gray-800 border border-gray-700 rounded-xl p-4 shadow-2xl w-72">
        <p class="text-sm text-gray-300 mb-3">Entrez votre numéro, je vous rappelle dans les minutes qui suivent.</p>
        <form id="callback-form-el" action="https://api.web3forms.com/submit" method="POST" class="flex gap-2">
          <input type="hidden" name="access_key" value="ba381790-1517-4d64-9295-a1f54769e4fd" />
          <input type="hidden" name="subject" value="Demande de rappel immédiat" />
          <input type="hidden" name="redirect" value="https://lecourtier.net/" />
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
          <input
            type="tel"
            id="callback-phone"
            name="phone"
            required
            placeholder="06 12 34 56 78"
            class="flex-1 px-3 py-2 rounded-lg bg-gray-900 border border-gray-600 text-white text-sm placeholder-gray-500 focus:ring-2 focus:ring-orange-500 focus:border-transparent outline-none"
          />
          <button type="submit" class="px-4 py-2 bg-orange-500 text-white text-sm font-bold rounded-lg hover:bg-orange-400 transition-colors">
            OK
          </button>
        </form>
        <p id="callback-success" class="hidden text-sm text-emerald-400 mt-2">Demande envoyée !</p>
      </div>
    </div>

    <script>
      // Callback sticker toggle
      document.getElementById('callback-toggle')?.addEventListener('click', () => {
        document.getElementById('callback-form')?.classList.toggle('hidden');
      });

      // Fade-in on scroll
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1 }
      );

      document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));

      // Closure overlay: show for humans, bots don't execute JS so they see the site
      (function() {
        var ua = navigator.userAgent.toLowerCase();
        var isBot = /bot|crawl|spider|slurp|bingpreview|facebookexternalhit|linkedinbot|twitterbot|whatsapp|telegram|googlebot|baiduspider|yandex|duckduckbot|sogou|exabot|ia_archiver|semrush|ahref|mj12bot|dotbot|petalbot|bytespider/i.test(ua);
        if (!isBot) {
          var overlay = document.getElementById('closure-overlay');
          if (overlay) overlay.style.display = 'flex';
          document.body.style.overflow = 'hidden';
        }
        document.getElementById('closure-show-docs')?.addEventListener('click', function() {
          document.getElementById('closure-docs')?.classList.toggle('hidden');
        });
      })();
    </script>
  </body>
</html>
