---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Développeur web freelance à Toulon — React, Next.js, Astro. Applications web modernes, rapides et sur mesure.' } = Astro.props;
---

<!doctype html>
<html lang="fr" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="développeur toulon, freelance toulon, astrojs toulon, reactjs toulon, next.js toulon, développeur web freelance var" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Sticker "Paiement au résultat" -->
    <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/contact`} class="fixed bottom-6 right-6 z-40 flex items-center gap-2 px-5 py-3 bg-emerald-500 text-white text-sm font-bold rounded-full shadow-lg shadow-emerald-500/30 hover:bg-emerald-400 hover:shadow-xl hover:shadow-emerald-400/40 hover:-translate-y-0.5 transition-all duration-200 animate-pulse">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0 1 12 2.944a11.955 11.955 0 0 1-8.618 3.04A12.02 12.02 0 0 0 3 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
      Paiement au résultat
    </a>

    <!-- Sticker "Rappel immédiat" -->
    <div id="callback-sticker" class="fixed left-0 top-1/2 -translate-y-1/2 z-40">
      <button id="callback-toggle" class="flex items-center gap-2 px-4 py-3 bg-orange-500 text-white text-sm font-bold rounded-r-full shadow-lg shadow-orange-500/30 hover:bg-orange-400 hover:shadow-xl transition-all duration-200">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        Rappel immédiat
      </button>
      <div id="callback-form" class="hidden absolute left-0 top-full mt-2 bg-gray-800 border border-gray-700 rounded-xl p-4 shadow-2xl w-72">
        <p class="text-sm text-gray-300 mb-3">Entrez votre numéro, je vous rappelle dans les minutes qui suivent.</p>
        <form id="callback-form-el" class="flex gap-2">
          <input
            type="tel"
            id="callback-phone"
            name="phone"
            required
            placeholder="06 12 34 56 78"
            class="flex-1 px-3 py-2 rounded-lg bg-gray-900 border border-gray-600 text-white text-sm placeholder-gray-500 focus:ring-2 focus:ring-orange-500 focus:border-transparent outline-none"
          />
          <button type="submit" class="px-4 py-2 bg-orange-500 text-white text-sm font-bold rounded-lg hover:bg-orange-400 transition-colors">
            OK
          </button>
        </form>
        <p id="callback-success" class="hidden text-sm text-emerald-400 mt-2">Demande envoyée !</p>
      </div>
    </div>

    <script>
      // Callback sticker toggle
      document.getElementById('callback-toggle')?.addEventListener('click', () => {
        document.getElementById('callback-form')?.classList.toggle('hidden');
      });

      // Callback form submit via mailto
      document.getElementById('callback-form-el')?.addEventListener('submit', (e) => {
        e.preventDefault();
        const phone = (document.getElementById('callback-phone') as HTMLInputElement)?.value;
        if (phone) {
          window.location.href = `mailto:contact@lecourtier.net?subject=Demande de rappel&body=Merci de me rappeler au ${encodeURIComponent(phone)}`;
          document.getElementById('callback-success')?.classList.remove('hidden');
          (document.getElementById('callback-form-el') as HTMLFormElement)?.reset();
        }
      });

      // Fade-in on scroll
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1 }
      );

      document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
