---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Développeur Web TIH à Toulon | RSE & Agefiph | Benoit Lecourtier" description="Travailleur indépendant handicapé (TIH) à Toulon. Valorisez votre engagement RSE et Agefiph en confiant vos projets web à un développeur reconnu.">

  <!-- Hero -->
  <section class="section-padding pt-32 md:pt-40">
    <div class="container-narrow">
      <div class="max-w-3xl fade-in">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-blue-500/10 border border-blue-500/20 rounded-full text-blue-400 text-sm font-medium mb-8">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0 1 12 2.944a11.955 11.955 0 0 1-8.618 3.04A12.02 12.02 0 0 0 3 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          Travailleur Indépendant Handicapé (TIH)
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-8">
          Alliez expertise technique
          <span class="text-blue-400">et engagement RSE.</span>
        </h1>
        <p class="text-lg md:text-xl text-text-dark-muted leading-relaxed max-w-2xl">
          Vous cherchez un développeur expert sur React, Next.js ou Astro, tout en souhaitant avoir un impact social positif ? En tant que Travailleur Indépendant Handicapé (TIH), faire appel à mes services en freelance vous permet d'atteindre vos objectifs techniques tout en réduisant votre contribution annuelle Agefiph ou FIPHFP.
        </p>
      </div>
    </div>
  </section>

  <!-- Déduction Agefiph -->
  <section class="section-padding bg-gray-900/50 border-y border-gray-800">
    <div class="container-narrow">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-8 fade-in">Comment fonctionne la déduction Agefiph ?</h2>
        <p class="text-text-dark-muted leading-relaxed mb-10 fade-in">
          Depuis la loi Macron de 2016, les entreprises qui collaborent avec un travailleur indépendant disposant d'une Reconnaissance en Qualité de Travailleur Handicapé (RQTH) peuvent déduire une partie de cette prestation de leur Obligation d'Emploi des Travailleurs Handicapés (OETH).
        </p>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="fade-in bg-gray-800/50 rounded-xl p-6 border border-gray-700/50">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg bg-blue-500/10 flex items-center justify-center text-blue-400">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <h3 class="text-lg font-semibold text-text-dark">Qui est concerné ?</h3>
            </div>
            <p class="text-text-dark-muted leading-relaxed">
              Toutes les entreprises du secteur privé ou public de <strong class="text-text-dark">plus de 20 salariés</strong>.
            </p>
          </div>

          <div class="fade-in bg-gray-800/50 rounded-xl p-6 border border-gray-700/50" style="transition-delay: 100ms">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center text-emerald-400">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <h3 class="text-lg font-semibold text-text-dark">Quel est l'avantage ?</h3>
            </div>
            <p class="text-text-dark-muted leading-relaxed">
              Vous pouvez déduire jusqu'à <strong class="text-emerald-400 text-xl">30 %</strong> du coût de la main-d'œuvre (hors matériel) de votre facture globale directement de votre taxe Agefiph ou FIPHFP.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pourquoi travailler avec moi -->
  <section class="section-padding">
    <div class="container-narrow">
      <h2 class="text-3xl md:text-4xl font-bold mb-16 text-center fade-in">Pourquoi travailler avec moi ?</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Excellence technique -->
        <div class="fade-in bg-gray-800/50 rounded-xl p-8 border border-gray-700/50 hover:border-blue-500/30 transition-colors">
          <div class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-400 mb-6">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>
          </div>
          <h3 class="text-xl font-semibold mb-3 text-text-dark">Excellence technique</h3>
          <p class="text-text-dark-muted leading-relaxed">
            Vous bénéficiez d'un code propre, performant et d'une stack moderne (AstroJS, Next.js, React). Je ne fais aucun compromis sur la qualité.
          </p>
        </div>

        <!-- Impact RSE -->
        <div class="fade-in bg-gray-800/50 rounded-xl p-8 border border-gray-700/50 hover:border-emerald-500/30 transition-colors" style="transition-delay: 100ms">
          <div class="w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-400 mb-6">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
          </div>
          <h3 class="text-xl font-semibold mb-3 text-text-dark">Impact RSE direct</h3>
          <p class="text-text-dark-muted leading-relaxed">
            Vous valorisez votre politique d'inclusion et d'achats responsables de manière concrète.
          </p>
        </div>

        <!-- Simplicité administrative -->
        <div class="fade-in bg-gray-800/50 rounded-xl p-8 border border-gray-700/50 hover:border-amber-500/30 transition-colors" style="transition-delay: 200ms">
          <div class="w-12 h-12 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-400 mb-6">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"/></svg>
          </div>
          <h3 class="text-xl font-semibold mb-3 text-text-dark">Simplicité administrative</h3>
          <p class="text-text-dark-muted leading-relaxed">
            La démarche est transparente et sans lourdeur pour votre service comptable.
          </p>
        </div>

        <!-- Communication 100 % écrite -->
        <div class="fade-in bg-gray-800/50 rounded-xl p-8 border border-gray-700/50 hover:border-purple-500/30 transition-colors" style="transition-delay: 300ms">
          <div class="w-12 h-12 rounded-xl bg-purple-500/10 flex items-center justify-center text-purple-400 mb-6">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/></svg>
          </div>
          <h3 class="text-xl font-semibold mb-3 text-text-dark">Communication 100 % écrite, 100 % efficace</h3>
          <p class="text-text-dark-muted leading-relaxed">
            Mon handicap affecte la parole, pas les compétences. Tous nos échanges se font par écrit : email, messagerie instantanée, outils de gestion de projet (Notion, Trello, Slack...). Loin d'être une limite, c'est un avantage concret : chaque échange est tracé, chaque décision documentée, zéro malentendu. Vos briefs, validations et retours restent accessibles à tout moment dans un historique clair.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- En pratique -->
  <section class="section-padding bg-gray-900/50 border-y border-gray-800">
    <div class="container-narrow">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-6 fade-in">En pratique, comment ça se passe ?</h2>
        <p class="text-text-dark-muted mb-12 fade-in">C'est extrêmement simple pour vous, il n'y a aucun dossier complexe à monter :</p>

        <div class="space-y-8">
          <!-- Step 1 -->
          <div class="fade-in flex gap-6 items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-blue-400 font-bold text-lg">1</div>
            <div>
              <h3 class="text-lg font-semibold text-text-dark mb-1">Le brief</h3>
              <p class="text-text-dark-muted leading-relaxed">Par email ou messagerie, nous cadrons ensemble votre besoin technique et je vous fournis un devis détaillé.</p>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="fade-in flex gap-6 items-start" style="transition-delay: 80ms">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-blue-400 font-bold text-lg">2</div>
            <div>
              <h3 class="text-lg font-semibold text-text-dark mb-1">La mission</h3>
              <p class="text-text-dark-muted leading-relaxed">Je développe votre projet avec le niveau d'exigence attendu.</p>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="fade-in flex gap-6 items-start" style="transition-delay: 160ms">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-blue-400 font-bold text-lg">3</div>
            <div>
              <h3 class="text-lg font-semibold text-text-dark mb-1">La facturation</h3>
              <p class="text-text-dark-muted leading-relaxed">En fin de mission (ou à chaque jalon), je vous envoie ma facture accompagnée de mon <strong class="text-text-dark">Attestation RQTH / TIH</strong>.</p>
            </div>
          </div>

          <!-- Step 4 -->
          <div class="fade-in flex gap-6 items-start" style="transition-delay: 240ms">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400 font-bold text-lg">4</div>
            <div>
              <h3 class="text-lg font-semibold text-text-dark mb-1">La déduction</h3>
              <p class="text-text-dark-muted leading-relaxed">Lors de votre déclaration annuelle (DOETH), votre comptable utilise simplement cette attestation et le montant de la facture pour calculer et appliquer votre déduction.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding">
    <div class="container-narrow">
      <div class="max-w-2xl mx-auto text-center fade-in">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Prêt à développer votre projet web de manière responsable ?</h2>
        <p class="text-text-dark-muted text-lg mb-10 leading-relaxed">
          Discutons de vos besoins techniques et voyons comment nous pouvons collaborer.
        </p>
        <a href="/contact" class="btn-primary text-lg px-8 py-4">Lancer mon projet</a>
      </div>
    </div>
  </section>

  <!-- FAQ Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Comment se déroule la communication avec un développeur TIH ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Tous les échanges se font par écrit (email, chat, outils collaboratifs comme Notion, Trello ou Slack). Chaque décision est documentée et traçable, ce qui garantit clarté et efficacité tout au long du projet."
        }
      },
      {
        "@type": "Question",
        "name": "Qu'est-ce qu'un Travailleur Indépendant Handicapé (TIH) ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Un TIH est un freelance disposant d'une Reconnaissance en Qualité de Travailleur Handicapé (RQTH). Les entreprises de plus de 20 salariés qui font appel à un TIH peuvent déduire jusqu'à 30 % du coût de la prestation de leur contribution Agefiph ou FIPHFP."
        }
      },
      {
        "@type": "Question",
        "name": "Comment fonctionne la déduction Agefiph avec un prestataire TIH ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Depuis la loi Macron de 2016, les entreprises collaborant avec un TIH peuvent déduire jusqu'à 30 % du coût de la main-d'œuvre (hors matériel) de leur Obligation d'Emploi des Travailleurs Handicapés (OETH). Il suffit de fournir la facture et l'attestation RQTH lors de la déclaration annuelle DOETH."
        }
      }
    ]
  })} />

  <!-- Logos Agefiph / FIPHFP -->
  <section class="py-12 px-6 border-t border-gray-800">
    <div class="container-narrow">
      <div class="flex flex-wrap items-center justify-center gap-10 opacity-50">
        <div class="flex items-center gap-3 text-text-dark-muted">
          <div class="w-10 h-10 rounded-lg bg-gray-700 flex items-center justify-center text-xs font-bold text-gray-400">AG</div>
          <span class="text-sm font-medium">Agefiph</span>
        </div>
        <div class="flex items-center gap-3 text-text-dark-muted">
          <div class="w-10 h-10 rounded-lg bg-gray-700 flex items-center justify-center text-xs font-bold text-gray-400">FI</div>
          <span class="text-sm font-medium">FIPHFP</span>
        </div>
        <div class="flex items-center gap-3 text-text-dark-muted">
          <div class="w-10 h-10 rounded-lg bg-gray-700 flex items-center justify-center text-xs font-bold text-gray-400">TIH</div>
          <span class="text-sm font-medium">Travailleur Indépendant Handicapé</span>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
