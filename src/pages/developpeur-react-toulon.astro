---
import BaseLayout from '../layouts/BaseLayout.astro';

const features = [
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>`,
    title: 'SPAs performantes',
    description: 'Applications monopages rapides et fluides avec React 19, Server Components et les dernières optimisations.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.241-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 010-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.28z"/><circle cx="12" cy="12" r="3"/></svg>`,
    title: 'Composants sur mesure',
    description: 'Design systems, bibliothèques de composants réutilisables, intégrations Syncfusion et Tailwind CSS.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75"/></svg>`,
    title: 'State management',
    description: 'Architecture d\'état robuste avec Redux, Zustand ou React Context selon la complexité de votre projet.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>`,
    title: 'Dashboards & Data',
    description: 'Tableaux de bord interactifs avec Recharts, graphiques temps réel et visualisation de données complexes.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M14.25 9.75L16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0020.25 18V6A2.25 2.25 0 0018 3.75H6A2.25 2.25 0 003.75 6v12A2.25 2.25 0 006 20.25z"/></svg>`,
    title: 'TypeScript natif',
    description: 'Typage strict, meilleure maintenabilité, refactoring en confiance et documentation auto-générée.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
    title: 'Tests & qualité',
    description: 'Tests unitaires et d\'intégration avec Jest, React Testing Library et Cypress pour un code fiable.',
  },
];

const useCases = [
  'Applications métier (CRM, ERP, gestion)',
  'Dashboards et interfaces d\'administration',
  'Portails clients et espaces membres',
  'Apps de réservation et planning',
  'Interfaces e-commerce avancées',
  'Outils de collaboration temps réel',
];
---

<BaseLayout title="Développeur React.js à Toulon | Sites & Applications Web Sur Mesure" description="Besoin d'un développeur React.js à Toulon ? Création de sites web et applications interactives, performantes et maintenables. Freelance disponible.">

  <!-- Hero -->
  <section class="section-padding pt-32 md:pt-40">
    <div class="container-narrow">
      <div class="max-w-3xl fade-in">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-cyan-500/10 border border-cyan-500/20 rounded-full text-cyan-400 text-sm font-medium mb-8">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="2.5"/><path d="M12 1.5C6.75 1.5 2.5 3.5 2.5 6s4.25 4.5 9.5 4.5S21.5 8.5 21.5 6 17.25 1.5 12 1.5z" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M7.5 3.5c-2.5 2-4 5.5-4 8.5s1.5 6.5 4 8.5" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M16.5 3.5c2.5 2 4 5.5 4 8.5s-1.5 6.5-4 8.5" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
          React.js
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6">
          Développeur <span class="text-cyan-400">React.js</span>
          freelance à Toulon
        </h1>
        <p class="text-lg md:text-xl text-text-dark-muted leading-relaxed mb-8 max-w-2xl">
          Je développe des applications web interactives, performantes et maintenables avec React.js. Des SPAs complexes aux interfaces métier — du code propre, typé et testé.
        </p>
        <div class="flex flex-wrap gap-4 mb-8">
          <div class="flex items-center gap-2 px-4 py-2 bg-gray-800/50 border border-gray-700/50 rounded-lg">
            <span class="text-lg">&#129351;</span>
            <span class="text-sm font-medium text-text-dark">8 ans d'expérience</span>
          </div>
          <div class="flex items-center gap-2 px-4 py-2 bg-gray-800/50 border border-gray-700/50 rounded-lg">
            <span class="text-lg">&#11088;</span>
            <span class="text-sm font-medium text-text-dark">5/5 sur +40 missions</span>
          </div>
        </div>
        <div class="flex flex-wrap gap-4">
          <a href="/contact" class="btn-primary">Parlons de votre projet React</a>
          <a href="/toulon-developpement" class="btn-secondary">Voir mes réalisations</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Expertises -->
  <section class="section-padding bg-gray-900/50 border-y border-gray-800">
    <div class="container-narrow">
      <h2 class="text-3xl md:text-4xl font-bold mb-16 text-center fade-in">Mon expertise React.js</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {features.map((f, i) => (
          <div class="fade-in bg-gray-800/50 rounded-xl p-6 border border-gray-700/50 hover:border-cyan-500/30 transition-colors" style={`transition-delay: ${i * 80}ms`}>
            <div class="w-10 h-10 rounded-lg bg-cyan-500/10 flex items-center justify-center text-cyan-400 mb-4" set:html={f.icon} />
            <h3 class="text-lg font-semibold text-text-dark mb-2">{f.title}</h3>
            <p class="text-sm text-text-dark-muted leading-relaxed">{f.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Cas d'usage -->
  <section class="section-padding">
    <div class="container-narrow">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-8 fade-in">Quand choisir React.js ?</h2>
        <p class="text-text-dark-muted leading-relaxed mb-10 fade-in">
          React est le choix idéal pour les applications web riches en interactions, les interfaces complexes et les projets qui nécessitent un écosystème mature et une large communauté.
        </p>
        <div class="grid sm:grid-cols-2 gap-4">
          {useCases.map((uc, i) => (
            <div class="fade-in flex items-center gap-3 px-4 py-3 bg-gray-800/30 rounded-lg border border-gray-700/30" style={`transition-delay: ${i * 60}ms`}>
              <span class="text-cyan-400 flex-shrink-0">&#10003;</span>
              <span class="text-sm text-text-dark">{uc}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Stack -->
  <section class="section-padding bg-gray-900/50 border-y border-gray-800">
    <div class="container-narrow">
      <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center fade-in">Écosystème React que je maîtrise</h2>
      <div class="flex flex-wrap justify-center gap-3 fade-in">
        {['React 19', 'TypeScript', 'Redux', 'Zustand', 'React Query', 'React Router', 'Tailwind CSS', 'Syncfusion', 'Recharts', 'Framer Motion', 'Jest', 'Cypress', 'Vite', 'Webpack'].map((tech) => (
          <span class="px-4 py-2 bg-gray-800/50 border border-gray-700/50 rounded-lg text-sm text-text-dark-muted">{tech}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding">
    <div class="container-narrow text-center fade-in">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Un projet React.js en tête ?</h2>
      <p class="text-text-dark-muted text-lg mb-10 max-w-2xl mx-auto">
        Discutons de votre projet. Paiement au résultat — vous ne payez que si le livrable vous satisfait.
      </p>
      <a href="/contact" class="btn-primary text-lg px-8 py-4">Me contacter</a>
    </div>
  </section>

</BaseLayout>
