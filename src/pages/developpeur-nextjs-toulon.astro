---
import BaseLayout from '../layouts/BaseLayout.astro';

const features = [
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z"/></svg>`,
    title: 'SSR & SSG',
    description: 'Rendu côté serveur et génération statique pour des performances maximales et un SEO parfait.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/></svg>`,
    title: 'API Routes',
    description: 'Backend intégré avec les API Routes et Server Actions — plus besoin d\'un serveur séparé.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>`,
    title: 'App Router & RSC',
    description: 'Architecture moderne avec l\'App Router, React Server Components et le streaming pour un TTI minimal.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5a2.25 2.25 0 002.25-2.25V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z"/></svg>`,
    title: 'Optimisation images',
    description: 'next/image, lazy loading natif, formats modernes (WebP, AVIF) et CDN pour des chargements instantanés.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125"/></svg>`,
    title: 'Base de données',
    description: 'Intégration Prisma, Drizzle ou Supabase pour une couche data robuste et typée de bout en bout.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.58-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"/></svg>`,
    title: 'Déploiement Vercel',
    description: 'CI/CD automatisé, preview deployments, edge functions et analytics intégrés sur Vercel.',
  },
];

const useCases = [
  'Sites vitrines SEO-friendly',
  'Plateformes SaaS full-stack',
  'E-commerce avec panier et paiement',
  'Blogs et sites de contenu',
  'Portails avec authentification',
  'Applications multi-tenant',
];
---

<BaseLayout title="Développeur Next.js à Toulon | Sites Rapides & Optimisés SEO" description="Développeur freelance Next.js à Toulon. Sites web ultra-rapides avec rendu serveur (SSR), SEO natif et performances optimales. Contactez-moi.">

  <!-- Hero -->
  <section class="section-padding pt-32 md:pt-40">
    <div class="container-narrow">
      <div class="max-w-3xl fade-in">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-white/5 border border-white/10 rounded-full text-white text-sm font-medium mb-8">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm-1.5 14.5V7.5l8 4.5-8 4.5z"/></svg>
          Next.js
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6">
          Développeur <span class="text-white">Next.js</span>
          freelance à Toulon
        </h1>
        <p class="text-lg md:text-xl text-text-dark-muted leading-relaxed mb-8 max-w-2xl">
          Je conçois des applications full-stack avec Next.js — le framework React pour la production. SSR, SSG, API Routes, App Router : des sites rapides, bien référencés et scalables.
        </p>
        <div class="flex flex-wrap gap-4 mb-8">
          <div class="flex items-center gap-2 px-4 py-2 bg-gray-800/50 border border-gray-700/50 rounded-lg">
            <span class="text-lg">&#129351;</span>
            <span class="text-sm font-medium text-text-dark">8 ans d'expérience</span>
          </div>
          <div class="flex items-center gap-2 px-4 py-2 bg-gray-800/50 border border-gray-700/50 rounded-lg">
            <span class="text-lg">&#11088;</span>
            <span class="text-sm font-medium text-text-dark">5/5 sur +40 missions</span>
          </div>
        </div>
        <div class="flex flex-wrap gap-4">
          <a href="/contact" class="btn-primary">Parlons de votre projet Next.js</a>
          <a href="/toulon-developpement" class="btn-secondary">Voir mes réalisations</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Expertises -->
  <section class="section-padding bg-gray-900/50 border-y border-gray-800">
    <div class="container-narrow">
      <h2 class="text-3xl md:text-4xl font-bold mb-16 text-center fade-in">Mon expertise Next.js</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {features.map((f, i) => (
          <div class="fade-in bg-gray-800/50 rounded-xl p-6 border border-gray-700/50 hover:border-white/20 transition-colors" style={`transition-delay: ${i * 80}ms`}>
            <div class="w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center text-white mb-4" set:html={f.icon} />
            <h3 class="text-lg font-semibold text-text-dark mb-2">{f.title}</h3>
            <p class="text-sm text-text-dark-muted leading-relaxed">{f.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Cas d'usage -->
  <section class="section-padding">
    <div class="container-narrow">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-8 fade-in">Quand choisir Next.js ?</h2>
        <p class="text-text-dark-muted leading-relaxed mb-10 fade-in">
          Next.js est le framework idéal quand vous avez besoin d'un site performant côté SEO avec des fonctionnalités dynamiques, ou d'une application full-stack sans la complexité d'un backend séparé.
        </p>
        <div class="grid sm:grid-cols-2 gap-4">
          {useCases.map((uc, i) => (
            <div class="fade-in flex items-center gap-3 px-4 py-3 bg-gray-800/30 rounded-lg border border-gray-700/30" style={`transition-delay: ${i * 60}ms`}>
              <span class="text-white flex-shrink-0">&#10003;</span>
              <span class="text-sm text-text-dark">{uc}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Stack -->
  <section class="section-padding bg-gray-900/50 border-y border-gray-800">
    <div class="container-narrow">
      <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center fade-in">Écosystème Next.js que je maîtrise</h2>
      <div class="flex flex-wrap justify-center gap-3 fade-in">
        {['Next.js 15', 'App Router', 'Server Components', 'Server Actions', 'TypeScript', 'Prisma', 'Supabase', 'Tailwind CSS', 'NextAuth.js', 'Stripe', 'Vercel', 'Edge Runtime', 'Middleware', 'ISR'].map((tech) => (
          <span class="px-4 py-2 bg-gray-800/50 border border-gray-700/50 rounded-lg text-sm text-text-dark-muted">{tech}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding">
    <div class="container-narrow text-center fade-in">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Un projet Next.js en tête ?</h2>
      <p class="text-text-dark-muted text-lg mb-10 max-w-2xl mx-auto">
        Discutons de votre projet. Paiement au résultat — vous ne payez que si le livrable vous satisfait.
      </p>
      <a href="/contact" class="btn-primary text-lg px-8 py-4">Me contacter</a>
    </div>
  </section>

</BaseLayout>
