---

<BaseLayout title="Développement web à Toulon | 22 projets réalisés | Benoit Lecourtier" description="Développeur web freelance à Toulon. Découvrez 22 projets réalisés avec React, Next.js et Astro pour des entreprises du Var et de la région PACA.">

  <section class="section-padding pt-32 md:pt-40">
    <div class="container-narrow">
      <div class="max-w-3xl mb-16 fade-in">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">
          Développement web
          <span class="text-blue-400">à Toulon</span>
        </h1>
        <p class="text-lg text-text-dark-muted leading-relaxed mb-4">
          Développeur freelance basé à Toulon, je conçois des applications web modernes, rapides et sur mesure avec React, Next.js et Astro pour les entreprises du Var et de la région PACA.
        </p>
        <p class="text-text-dark-muted leading-relaxed">
          <strong class="text-text-dark">22 projets livrés</strong> — sites vitrines, applications métier, dashboards, e-commerce et plateformes SaaS.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((project, i) => (
          <ProjectCard {...project} delay={i * 50} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section-padding bg-gray-900/50">
    <div class="container-narrow text-center fade-in">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Un projet en tête ?</h2>
      <p class="text-text-dark-muted text-lg mb-8 max-w-2xl mx-auto">
        Discutons de votre projet. Paiement au résultat — vous ne payez que si le livrable vous satisfait.
      </p>
      <a href="/contact" class="btn-primary text-lg px-8 py-4">Parlons de votre projet</a>
    </div>
  </section>

</BaseLayout>
