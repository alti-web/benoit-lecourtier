---
import BaseLayout from '../layouts/BaseLayout.astro';

const features = [
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>`,
    title: 'Zéro JS par défaut',
    description: 'Astro n\'envoie aucun JavaScript au navigateur par défaut. Résultat : des pages ultra-rapides et un Lighthouse à 100.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M20.893 13.393l-1.135-1.135a2.252 2.252 0 01-.421-.585l-1.08-2.16a.414.414 0 00-.663-.107.827.827 0 01-.812.21l-1.273-.363a.89.89 0 00-.738 1.595l.587.39c.59.395.674 1.23.172 1.732l-.2.2c-.212.212-.33.498-.33.796v.41c0 .409-.11.809-.32 1.158l-1.315 2.191a2.11 2.11 0 01-1.81 1.025 1.055 1.055 0 01-1.055-1.055v-1.172c0-.92-.56-1.747-1.414-2.089l-.655-.261a2.25 2.25 0 01-1.383-2.46l.007-.042a2.25 2.25 0 01.29-.787l.09-.15a2.25 2.25 0 012.37-1.048l1.178.236c.093.018.19.013.28-.015l.646-.215a.89.89 0 00.26-1.508l-.645-.484a.877.877 0 01-.26-.625V6.935a1.5 1.5 0 00-1.5-1.5h-.096c-.342 0-.66.183-.832.478l-.222.385a1.32 1.32 0 01-2.03.393l-.372-.31A2.25 2.25 0 003 7.703v.75"/></svg>`,
    title: 'Islands Architecture',
    description: 'Hydratation sélective : seuls les composants interactifs chargent du JS. Le reste est du HTML pur.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z"/></svg>`,
    title: 'Content-first',
    description: 'MDX, Markdown, Content Collections — idéal pour les blogs, la documentation et les sites éditoriaux.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>`,
    title: 'SEO natif',
    description: 'HTML statique, méta-tags optimisés, sitemap auto-généré et temps de chargement < 1 seconde.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 01-.657.643 48.491 48.491 0 01-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 01-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 00-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 01-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 00.657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 01-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.4.604-.4.959v0c0 .333.277.599.61.58a48.1 48.1 0 005.427-.63 48.05 48.05 0 00.582-4.717.532.532 0 00-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.96.401v0a.656.656 0 00.658-.663 48.422 48.422 0 00-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 01-.61-.58v0z"/></svg>`,
    title: 'Multi-framework',
    description: 'Intégrez des composants React, Vue ou Svelte dans le même projet Astro selon vos besoins.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: 'Coût d\'hébergement nul',
    description: 'Sites statiques déployables gratuitement sur Netlify, Vercel ou Cloudflare Pages.',
  },
];

const useCases = [
  'Sites vitrines et landing pages',
  'Blogs et magazines en ligne',
  'Documentation technique',
  'Sites portfolio et showroom',
  'Sites d\'entreprise multi-pages',
  'Microsites événementiels',
];
---

<BaseLayout title="Développeur Astro JS à Toulon | Freelance expert Astro | Benoit Lecourtier" description="Développeur Astro JS freelance à Toulon. Sites ultra-rapides, 0 KB de JS, Lighthouse 100. 8 ans d'expérience, paiement au résultat.">

  <!-- Hero -->
  <section class="section-padding pt-32 md:pt-40">
    <div class="container-narrow">
      <div class="max-w-3xl fade-in">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-orange-500/10 border border-orange-500/20 rounded-full text-orange-400 text-sm font-medium mb-8">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M16.074 2.576l-5.09 14.3c-.157.44.346.793.698.49l4.966-4.267a.5.5 0 01.652 0l4.966 4.268c.352.302.855-.051.698-.49l-5.09-14.3a.873.873 0 00-1.8 0z"/><path d="M8.074 7.576l-5.09 14.3c-.157.44.346.793.698.49l4.966-4.267a.5.5 0 01.652 0l4.966 4.268c.352.302.855-.051.698-.49l-5.09-14.3a.873.873 0 00-1.8 0z" opacity="0.5"/></svg>
          Astro JS
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6">
          Développeur <span class="text-orange-400">Astro JS</span>
          freelance à Toulon
        </h1>
        <p class="text-lg md:text-xl text-text-dark-muted leading-relaxed mb-8 max-w-2xl">
          Je crée des sites web ultra-rapides avec Astro — zéro JavaScript par défaut, Lighthouse 100, SEO natif. Le framework idéal pour les sites vitrines, blogs et landing pages.
        </p>
        <div class="flex flex-wrap gap-4 mb-8">
          <div class="flex items-center gap-2 px-4 py-2 bg-gray-800/50 border border-gray-700/50 rounded-lg">
            <span class="text-lg">&#129351;</span>
            <span class="text-sm font-medium text-text-dark">8 ans d'expérience</span>
          </div>
          <div class="flex items-center gap-2 px-4 py-2 bg-gray-800/50 border border-gray-700/50 rounded-lg">
            <span class="text-lg">&#11088;</span>
            <span class="text-sm font-medium text-text-dark">5/5 sur +40 missions</span>
          </div>
          <div class="flex items-center gap-2 px-4 py-2 bg-orange-500/10 border border-orange-500/20 rounded-lg">
            <span class="text-sm font-bold text-orange-400">Lighthouse 100</span>
          </div>
        </div>
        <div class="flex flex-wrap gap-4">
          <a href="/contact" class="btn-primary">Parlons de votre projet Astro</a>
          <a href="/toulon-developpement" class="btn-secondary">Voir mes réalisations</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Expertises -->
  <section class="section-padding bg-gray-900/50 border-y border-gray-800">
    <div class="container-narrow">
      <h2 class="text-3xl md:text-4xl font-bold mb-16 text-center fade-in">Mon expertise Astro JS</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {features.map((f, i) => (
          <div class="fade-in bg-gray-800/50 rounded-xl p-6 border border-gray-700/50 hover:border-orange-500/30 transition-colors" style={`transition-delay: ${i * 80}ms`}>
            <div class="w-10 h-10 rounded-lg bg-orange-500/10 flex items-center justify-center text-orange-400 mb-4" set:html={f.icon} />
            <h3 class="text-lg font-semibold text-text-dark mb-2">{f.title}</h3>
            <p class="text-sm text-text-dark-muted leading-relaxed">{f.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Cas d'usage -->
  <section class="section-padding">
    <div class="container-narrow">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-8 fade-in">Quand choisir Astro JS ?</h2>
        <p class="text-text-dark-muted leading-relaxed mb-10 fade-in">
          Astro est le choix parfait quand la performance et le SEO sont prioritaires. Pour les sites orientés contenu qui doivent charger en un éclair et se positionner en haut des résultats Google.
        </p>
        <div class="grid sm:grid-cols-2 gap-4">
          {useCases.map((uc, i) => (
            <div class="fade-in flex items-center gap-3 px-4 py-3 bg-gray-800/30 rounded-lg border border-gray-700/30" style={`transition-delay: ${i * 60}ms`}>
              <span class="text-orange-400 flex-shrink-0">&#10003;</span>
              <span class="text-sm text-text-dark">{uc}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Comparatif perf -->
  <section class="section-padding bg-gray-900/50 border-y border-gray-800">
    <div class="container-narrow">
      <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center fade-in">Pourquoi Astro est si rapide ?</h2>
      <div class="max-w-2xl mx-auto space-y-6 fade-in">
        <div class="flex items-center justify-between p-4 bg-gray-800/50 rounded-lg border border-gray-700/50">
          <span class="text-text-dark font-medium">JavaScript envoyé au client</span>
          <span class="text-orange-400 font-bold">0 KB par défaut</span>
        </div>
        <div class="flex items-center justify-between p-4 bg-gray-800/50 rounded-lg border border-gray-700/50">
          <span class="text-text-dark font-medium">First Contentful Paint (FCP)</span>
          <span class="text-orange-400 font-bold">< 0.5s</span>
        </div>
        <div class="flex items-center justify-between p-4 bg-gray-800/50 rounded-lg border border-gray-700/50">
          <span class="text-text-dark font-medium">Time to Interactive (TTI)</span>
          <span class="text-orange-400 font-bold">< 0.5s</span>
        </div>
        <div class="flex items-center justify-between p-4 bg-gray-800/50 rounded-lg border border-gray-700/50">
          <span class="text-text-dark font-medium">Score Lighthouse</span>
          <span class="text-orange-400 font-bold">100 / 100</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Stack -->
  <section class="section-padding">
    <div class="container-narrow">
      <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center fade-in">Écosystème Astro que je maîtrise</h2>
      <div class="flex flex-wrap justify-center gap-3 fade-in">
        {['Astro 5', 'Content Collections', 'MDX', 'Tailwind CSS', 'View Transitions', 'Islands', 'React (islands)', 'Starlight', 'Pagefind', 'Sharp', 'Netlify', 'Vercel', 'Cloudflare Pages', 'SSR Adapter'].map((tech) => (
          <span class="px-4 py-2 bg-gray-800/50 border border-gray-700/50 rounded-lg text-sm text-text-dark-muted">{tech}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-gray-900/50 border-t border-gray-800">
    <div class="container-narrow text-center fade-in">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Un projet Astro en tête ?</h2>
      <p class="text-text-dark-muted text-lg mb-10 max-w-2xl mx-auto">
        Discutons de votre projet. Paiement au résultat — vous ne payez que si le livrable vous satisfait.
      </p>
      <a href="/contact" class="btn-primary text-lg px-8 py-4">Me contacter</a>
    </div>
  </section>

</BaseLayout>
