---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Blog — Conseils Techniques Développement Web | Toulon" description="Articles et conseils ultra-techniques sur React.js, Next.js, Astro JS et TypeScript par un développeur freelance basé à Toulon.">

  <section class="section-padding pt-32 md:pt-40">
    <div class="container-narrow">
      <div class="fade-in text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Blog</h1>
        <p class="text-lg text-text-muted dark:text-text-dark-muted max-w-2xl mx-auto">
          Retours d'expérience et conseils techniques — React.js, Next.js, Astro JS, TypeScript — depuis Toulon.
        </p>
      </div>

      <div class="space-y-8">
        {posts.map((post) => (
          <article class="fade-in group">
            <a href={`${base}/blog/${post.id}`} class="block p-6 rounded-2xl border border-gray-700/50 bg-gray-800/30 hover:bg-gray-800/60 hover:border-gray-600 transition-all duration-200">
              <div class="flex flex-wrap items-center gap-3 mb-3">
                <time class="text-sm text-text-dark-muted" datetime={post.data.date}>
                  {new Date(post.data.date).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                {post.data.tags.map((tag: string) => (
                  <span class="text-xs font-medium px-2.5 py-0.5 rounded-full bg-accent/10 text-blue-400">{tag}</span>
                ))}
              </div>
              <h2 class="text-xl md:text-2xl font-bold mb-2 group-hover:text-blue-400 transition-colors">{post.data.title}</h2>
              <p class="text-text-muted dark:text-text-dark-muted">{post.data.description}</p>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
