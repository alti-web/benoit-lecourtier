---

<BaseLayout title="Avis Clients | Développeur Web Freelance Toulon | Benoit Lecourtier" description="Découvrez les avis de mes clients sur mes prestations de développement web React, Next.js et Astro à Toulon. +40 missions réalisées, 5/5 de satisfaction.">

  <!-- Hero -->
  <section class="section-padding pt-32 md:pt-40">
    <div class="container-narrow">
      <div class="max-w-3xl fade-in">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6">
          Ce que disent <span class="text-blue-400">mes clients</span>
        </h1>
        <p class="text-lg md:text-xl text-text-dark-muted leading-relaxed mb-8 max-w-2xl">
          Plus de 40 missions réalisées avec une satisfaction client de 5/5. Découvrez les retours de ceux qui m'ont fait confiance.
        </p>
        <div class="flex flex-wrap gap-4">
          <div class="flex items-center gap-2 px-4 py-2 bg-gray-800/50 border border-gray-700/50 rounded-lg">
            <span class="text-lg">&#11088;</span>
            <span class="text-sm font-medium text-text-dark">5/5 de satisfaction</span>
          </div>
          <div class="flex items-center gap-2 px-4 py-2 bg-gray-800/50 border border-gray-700/50 rounded-lg">
            <span class="text-lg">&#129351;</span>
            <span class="text-sm font-medium text-text-dark">+40 missions réalisées</span>
          </div>
          <div class="flex items-center gap-2 px-4 py-2 bg-gray-800/50 border border-gray-700/50 rounded-lg">
            <span class="text-lg">&#128176;</span>
            <span class="text-sm font-medium text-text-dark">Paiement au résultat</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Avis Section -->
  <section class="section-padding" id="avis">
    <div class="container-narrow">
      <div id="reviews-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {reviews.map((review, i) => (
          <div
            class="review-card fade-in bg-gray-800/50 rounded-xl p-6 border border-gray-700/50 hover:border-blue-500/30 transition-all duration-300"
            data-review-index={i}
            style={`transition-delay: ${(i % 6) * 80}ms`}
          >
            <div class="flex items-center gap-1 mb-4">
              {[...Array(review.rating)].map(() => (
                <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-text-dark-muted leading-relaxed mb-4 text-sm">{review.text}</p>
            <div class="flex items-center gap-3 pt-4 border-t border-gray-700/50">
              <div class="w-10 h-10 rounded-full bg-accent/20 flex items-center justify-center text-blue-400 font-bold text-sm">
                {review.name.split(' ').map(n => n[0]).join('')}
              </div>
              <div>
                <p class="text-sm font-semibold text-text-dark">{review.name}</p>
                <p class="text-xs text-text-dark-muted">{review.role} — {review.company}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div id="more-reviews-notice" class="hidden mt-8 text-center fade-in">
        <p class="text-text-dark-muted text-sm">De nouveaux avis sont ajoutés régulièrement.</p>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section-padding bg-gray-900/50 border-y border-gray-800" id="faq">
    <div class="container-narrow">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center fade-in">Questions fréquentes</h2>
        <div class="space-y-4" id="faq-list">
          {faqItems.map((item, i) => (
            <div class="fade-in faq-item bg-gray-800/50 rounded-xl border border-gray-700/50 overflow-hidden" style={`transition-delay: ${i * 80}ms`}>
              <button
                class="faq-toggle w-full flex items-center justify-between p-6 text-left hover:bg-gray-700/20 transition-colors"
                aria-expanded="false"
              >
                <span class="text-text-dark font-semibold pr-4">{item.question}</span>
                <svg class="faq-icon w-5 h-5 text-text-dark-muted flex-shrink-0 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="faq-content hidden px-6 pb-6">
                <p class="text-text-dark-muted leading-relaxed">{item.answer}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding">
    <div class="container-narrow">
      <div class="max-w-2xl mx-auto text-center fade-in">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Convaincu ? Parlons de votre projet</h2>
        <p class="text-text-dark-muted text-lg mb-10 leading-relaxed">
          Rejoignez mes clients satisfaits et lancez votre projet web dès maintenant.
        </p>
        <a href={`${base}/contact`} class="btn-primary text-lg px-8 py-4">Demander un devis gratuit</a>
      </div>
    </div>
  </section>

  <!-- FAQ Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer,
      },
    })),
  })} />

  <!-- Progressive reviews + FAQ accordion -->
  <script>
    // Progressive review display: start with 7, add 1 every 7 days
    const START_DATE = new Date('2025-11-15');
    const BASE_COUNT = 7;
    const cards = document.querySelectorAll<HTMLElement>('.review-card');
    const now = new Date();
    const weeksElapsed = Math.floor((now.getTime() - START_DATE.getTime()) / (7 * 24 * 60 * 60 * 1000));
    const visibleCount = Math.min(Math.max(BASE_COUNT, BASE_COUNT + weeksElapsed), cards.length);

    cards.forEach((card, i) => {
      if (i >= visibleCount) {
        card.style.display = 'none';
      }
    });

    if (visibleCount < cards.length) {
      document.getElementById('more-reviews-notice')?.classList.remove('hidden');
    }

    // FAQ accordion
    document.querySelectorAll('.faq-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        if (!item) return;
        const content = item.querySelector('.faq-content');
        const icon = item.querySelector('.faq-icon');
        const isOpen = btn.getAttribute('aria-expanded') === 'true';

        // Close all others
        document.querySelectorAll('.faq-item').forEach(other => {
          if (other !== item) {
            other.querySelector('.faq-content')?.classList.add('hidden');
            other.querySelector('.faq-icon')?.classList.remove('rotate-180');
            other.querySelector('.faq-toggle')?.setAttribute('aria-expanded', 'false');
          }
        });

        // Toggle current
        content?.classList.toggle('hidden');
        icon?.classList.toggle('rotate-180');
        btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
      });
    });
  </script>

</BaseLayout>
